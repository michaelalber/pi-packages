{
  "name": "@malber/pi-industrial",
  "version": "0.1.0",
  "description": "Pi coding harness for Industrial Automation — SCADA, PLC, MODBUS, OPC UA, Python, Rust",
  "license": "MIT",
  "author": "Michael Alber",
  "keywords": [
    "pi",
    "industrial",
    "automation",
    "scada",
    "plc",
    "modbus",
    "opcua",
    "ollama",
    "coding-agent",
    "local-ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/malber/pi-packages"
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/prepublish.js pi-industrial"
  },
  "pi": {
    "name": "industrial",
    "description": "Industrial Automation — SCADA, PLC, MODBUS, OPC UA, Python, Rust — with grounded-code-mcp RAG",
    "skills": [
      "skills/industrial.md"
    ],
    "prompts": [
      { "name": "fix",       "file": "prompts/fix.md" },
      { "name": "review",    "file": "prompts/review.md" },
      { "name": "generate",  "file": "prompts/generate.md" },
      { "name": "explain",   "file": "prompts/explain.md" },
      { "name": "decompose", "file": "prompts/decompose.md" }
    ],
    "extensions": [
      "extensions/rag.ts",
      "extensions/router.ts",
      "extensions/budget.ts",
      "extensions/project-detect.ts"
    ]
  }
}
