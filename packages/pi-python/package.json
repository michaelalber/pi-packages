{
  "name": "@malber/pi-python",
  "version": "0.1.0",
  "description": "Pi coding harness for Python 3 / FastAPI / Pydantic / pytest projects",
  "license": "MIT",
  "author": "Michael Alber",
  "keywords": [
    "pi",
    "python",
    "fastapi",
    "pydantic",
    "ollama",
    "coding-agent",
    "local-ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/malber/pi-packages"
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/prepublish.js pi-python"
  },
  "pi": {
    "name": "python",
    "description": "Python 3 / FastAPI / Pydantic v2 / pytest — with grounded-code-mcp RAG",
    "skills": [
      "skills/python.md"
    ],
    "prompts": [
      { "name": "fix",       "file": "prompts/fix.md" },
      { "name": "review",    "file": "prompts/review.md" },
      { "name": "generate",  "file": "prompts/generate.md" },
      { "name": "explain",   "file": "prompts/explain.md" },
      { "name": "decompose", "file": "prompts/decompose.md" }
    ],
    "extensions": [
      "extensions/rag.ts",
      "extensions/router.ts",
      "extensions/budget.ts",
      "extensions/project-detect.ts"
    ]
  }
}
