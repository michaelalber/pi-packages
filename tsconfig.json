{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "preserveSymlinks": false,
    "typeRoots": [
      "./shared/types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "shared/**/*.ts",
    "packages/**/*.ts"
  ]
}
